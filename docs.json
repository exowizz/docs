          },
          {
            "group": "Resources",
            "pages": [
              "resources/overview",
              "resources/transforms",
              "resources/ownership",
              "resources/search",
              "resources/crud"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/overview",
              "webhooks/subscriptions",
              "webhooks/security"
            ]
          },
          {
            "group": "Exo Cloud",
            "pages": [
              "cloud/overview",
              "cloud/setup"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "configuration",
              "commands"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "api-reference/resources/whoami",
