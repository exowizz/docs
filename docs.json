              "api-reference/resources/create",
              "api-reference/resources/update",
              "api-reference/resources/delete"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks/list",
              "api-reference/webhooks/create",
              "api-reference/webhooks/show",
              "api-reference/webhooks/update",
              "api-reference/webhooks/delete",
              "api-reference/webhooks/payload"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Home Page",
          "href": "https://exowizz.com",
          "icon": "house"
        },
        {
          "anchor": "Blog",
          "href": "https://exowizz.com/blog",
          "icon": "newspaper"
        }
      ]
